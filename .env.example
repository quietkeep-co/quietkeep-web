# Copy to .env.local for local dev, and set the same vars in Vercel's
# Project Settings -> Environment Variables for production.

# GoHighLevel "Quietkeep Updates" email form embed URL.
# GHL: Sites -> Forms -> your form -> Integrate/Share -> copy the
# https://api.leadconnectorhq.com/widget/form/<id> link.
# Leave unset and the Updates section falls back to a mailto link.
NEXT_PUBLIC_GHL_FORM_URL=
